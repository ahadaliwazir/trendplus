{
    "name": "dramalist-api",
    "version": "1.0.0",
    "description": "DramaList Pakistan - Backend API with Express and Sequelize",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:seed": "npx sequelize-cli db:seed:all",
        "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
    },
    "keywords": [
        "dramalist",
        "pakistani-dramas",
        "api",
        "express",
        "sequelize"
    ],
    "author": "DramaList Pakistan",
    "license": "MIT",
    "dependencies": {
        "@supabase/supabase-js": "^2.105.1",
        "axios": "^1.13.2",
        "bcryptjs": "^2.4.3",
        "cheerio": "^1.1.2",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.0.1",
        "googleapis": "^171.4.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "mysql2": "^3.11.0",
        "node-cache": "^5.1.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^7.0.12",
        "pg": "^8.20.0",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.35.2",
        "sequelize-cli": "^6.6.2",
        "user-agent-array": "^2.0.1",
        "@google/generative-ai": "latest"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "jest": "^30.2.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    }
}
